generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./music.db"
}

model Playlist {
  id    Int    @id @default(autoincrement())
  name  String
  songs PlaylistSong[]
}

model PlaylistSong {
  id         Int @id @default(autoincrement())
  playlistId Int
  filename   String

  playlist Playlist @relation(fields: [playlistId], references: [id])
}